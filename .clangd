# .clangd configuration for Linux C++ projects
# Place this in your project root or ~/.config/clangd/

CompileFlags:
  # Tells clangd to use GCC's include paths and built-in defines
  Compiler: g++
  # Use the same C++ standard as your build system (adjust as needed)
  Add:
    - -std=c++17          # or c++20, c++14, etc.
    - -stdlib=libstdc++   # GNU standard library (Linux default)
    - -D_GNU_SOURCE       # Common Linux feature test macro

  # Remove flags that clangd doesn't understand or need
  Remove:
    - -mno-direct-extern-access
    - -march=*            # Architecture-specific optimizations
    - -mtune=*            # Tuning flags
    - -pipe               # Pipe optimization (compiler-only)
    - -fno-plt            # Procedure linkage table optimizations
    - -fstack-protector*  # Stack protection (clangd doesn't execute)
    - -fcf-protection     # Control-flow protection
    - -Wa,*               # Assembler flags
    - -Wp,*               # Preprocessor flags

Diagnostics:
  # Clang-tidy integration (optional but recommended)
  ClangTidy:
    Add:
    #   - bugprone-*        # Bug prevention checks
    #   - cppcoreguidelines-*  # C++ best practices
      - modernize-*       # Modernization suggestions
    #   - performance-*     # Performance optimizations
      - portability-*     # Portability checks
    #   - readability-*     # Readability improvements
    Remove:
      - modernize-use-trailing-return-type  # Personal preference
      - cppcoreguidelines-avoid-magic-numbers  # Can be noisy
    # CheckOptions:
    #   readability-identifier-naming.VariableCase: camelBack
    #   readability-identifier-naming.FunctionCase: CamelCase

  # Suppress specific false positives if needed
  Suppress:
    - invalid_operands    # Your specific error if it persists

Index:
  # Performance tuning for large codebases
  Background: Build
  StandardLibrary: No    # Don't index standard library (faster)

InlayHints:
  # Modern IDE features (if your Emacs supports it)
  Enabled: No
  ParameterNames: Yes
  DeducedTypes: Yes

If:
  PathExclude: third_party/.*
