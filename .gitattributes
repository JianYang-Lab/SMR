# Ensure all text files use LF
* text=auto eol=lf

# Explicitly set line endings for common file types
*.c     text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf
*.cc    text eol=lf
*.py    text eol=lf
*.sh    text eol=lf

# Binary files — never normalize or diff
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.mp4   binary
*.mp3   binary
*.exe   binary
*.dll   binary
*.so    binary
*.a     binary
*.o     binary
